{
  "groups": [
    {
      "borderColor": "#FF00FF37",
      "color": "#27C04F",
      "id": "gq",
      "isExpanded": true,
      "name": "Quality"
    },
    {
      "borderColor": "#FF858283",
      "color": "#FFBE01",
      "id": "gr",
      "isExpanded": true,
      "name": "Resolution"
    },
    {
      "borderColor": "#FF858283",
      "color": "#FF6B6B",
      "id": "gv",
      "isExpanded": true,
      "name": "Visual"
    },
    {
      "borderColor": "#00000000",
      "color": "#45B7D1",
      "id": "ga",
      "isExpanded": true,
      "name": "Audio"
    },
    {
      "borderColor": "#00000000",
      "color": "#FFD700",
      "id": "gc",
      "isExpanded": true,
      "name": "Channels"
    }
  ],
  "filters": [
    {
      "borderColor": "#00000000",
      "groupId": "gq",
      "id": "q-z",
      "imageURL": "https://raw.githubusercontent.com/njuart/Test/20b0786f01649e481982a7d03ddbe1ddb311a071/nuvio_logo.png",
      "isEnabled": true,
      "name": "Instant",
      "pattern": "(?i)^(?=.*\\binstant\\b)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gq",
      "id": "q-r",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-remux.png",
      "isEnabled": true,
      "name": "Remux",
      "pattern": "(?i)\\bremux|bdremux\\b",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gq",
      "id": "q-b",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-bluray.png",
      "isEnabled": true,
      "name": "BluRay",
      "pattern": "(?i)^(?=.*(?:bluray|blu-ray|bdrip|brrip))(?!.*remux)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gq",
      "id": "q-w",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-webdl.png",
      "isEnabled": true,
      "name": "WebDL",
      "pattern": "(?i)\\b(?:web[-_. ]?dl|webdl|webrip|web-rip|web)\\b",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gr",
      "id": "r-4k",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/4k.png",
      "isEnabled": true,
      "name": "4K",
      "pattern": "(?i)^(?=.*(?:2160[pi]?|4k|uhd))(?!.*(?:1080[pi]?|720[pi]?))",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gr",
      "id": "r-1080",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/1080p.png",
      "isEnabled": true,
      "name": "1080p",
      "pattern": "(?i)\\b1080[pi]?\\b",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gr",
      "id": "r-720",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/720p.png",
      "isEnabled": true,
      "name": "720p",
      "pattern": "(?i)\\b720[pi]?\\b",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gv",
      "id": "v-hdr10p",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/HDR10Plus.png",
      "isEnabled": true,
      "name": "HDR10+",
      "pattern": "(?i)^(?=.*hdr[\\s._-]?10[\\s._-]?(?:\\\\+|plus|p))",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gv",
      "id": "v-hdr10",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/HDR10.png",
      "isEnabled": true,
      "name": "HDR10",
      "pattern": "(?i)^(?=.*hdr[\\s._-]?10)(?!.*hdr[\\s._-]?10[\\s._-]?(?:\\\\+|plus|p))",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gv",
      "id": "v-hdr",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/HDR.png",
      "isEnabled": true,
      "name": "HDR",
      "pattern": "(?i)^(?=.*\\bHDR\\b)(?!.*hdr[\\s._-]?10)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gv",
      "id": "v-imax-e",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/IMAX-enhanced.png",
      "isEnabled": true,
      "name": "IMAX Enhanced",
      "pattern": "(?i)\\bimax[\\s._-]?enhanced\\b",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gv",
      "id": "v-imax",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/IMAX.png",
      "isEnabled": true,
      "name": "IMAX",
      "pattern": "(?i)^(?=.*\\bIMAX\\b)(?!.*enhanced)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dtsx",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtsx.png",
      "isEnabled": true,
      "name": "DTS:X",
      "pattern": "(?i)\\bdts[-_.: ]?x\\b",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dtsma",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtshdma.png",
      "isEnabled": true,
      "name": "DTS-HD MA",
      "pattern": "(?i)^(?=.*\\bdts[-_. ]?(?:hd[-_. ]?)?ma\\b)(?!.*\\bdts[-_.: ]?x\\b)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dtshd",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dtshd.png",
      "isEnabled": true,
      "name": "DTS-HD",
      "pattern": "(?i)^(?=.*\\bdts[-_. ]?hd\\b)(?!.*\\bdts[-_. ]?(?:hd[-_. ]?)?ma\\b)(?!.*\\bdts[-_.: ]?x\\b)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dts",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/dts.png",
      "isEnabled": true,
      "name": "DTS",
      "pattern": "(?i)^(?=.*\\bDTS\\b)(?!.*\\bdts[-_. ]?(?:hd|ma|xll|x)\\b)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-at",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/atmos.png",
      "isEnabled": true,
      "name": "Atmos",
      "pattern": "(?i)\\batmos\\b",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-th",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/truehd.png",
      "isEnabled": true,
      "name": "TrueHD",
      "pattern": "(?i)^(?=.*\\btrue[\\s._-]?hd\\b)(?!.*\\batmos\\b)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dp",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/digitalplus.png",
      "isEnabled": true,
      "name": "DD+",
      "pattern": "(?i)^(?=.*(?:\\bddp|\\bdd\\+|\\beac-?3|\\be-?ac-?3))(?!.*\\batmos\\b)(?!.*\\btrue[\\s._-]?hd\\b)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "ga",
      "id": "a-dd",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/digital.png",
      "isEnabled": true,
      "name": "DD",
      "pattern": "(?i)^(?=.*\\b(?:dd[25][. ][01]|dd[^p+a-z]\\b|\\bac-?3)\\b)(?!.*(?:\\bddp|\\bdd\\+|\\beac-?3|\\be-?ac-?3))(?!.*\\btrue[\\s._-]?hd\\b)(?!.*\\batmos\\b)",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gc",
      "id": "ch-71",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/7dot1.png",
      "isEnabled": true,
      "name": "7.1",
      "pattern": "[^0-9][7-8][. ][01](?![0-9])",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gc",
      "id": "ch-51",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/5dot1.png",
      "isEnabled": true,
      "name": "5.1",
      "pattern": "^(?=.*[^0-9]5[. ][01](?![0-9]))(?!.*[^0-9][7-8][. ][01](?![0-9]))",
      "tagColor": "#00000000",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    }
  ]
}
